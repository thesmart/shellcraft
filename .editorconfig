# Editor configuration, see http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.sh]
indent_style = tab
max_line_length = 88

[*.md]
indent_style = space
indent_size = 2
max_line_length = 99

[*.{html,htm}]
indent_style = space
indent_size = 2
max_line_length = 99

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.{xml,svg}]
indent_style = space
indent_size = 2

[*.py]
# Python convention is 4 spaces per PEP 8
indent_style = space
max_line_length = 88

[*.toml]
indent_style = space
indent_size = 2

[*.txt]
indent_style = space
indent_size = 2
